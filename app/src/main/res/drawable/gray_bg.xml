<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Soft gradient from green to white -->
    <gradient
        android:startColor="@color/input_background"
        android:endColor="@color/surface_card"
        android:angle="90"/>

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>


    <!-- Optional shadow effect (requires API 21+) -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>
</shape>
