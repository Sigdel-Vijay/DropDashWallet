<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bottom_sheet_bg"
    android:gravity="center">

    <!-- Drag Handle -->
    <View
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:layout_marginBottom="20dp"
        android:background="#CCCCCC" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My QR Code"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"/>

    <ImageView
        android:id="@+id/qrImage"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/esewa_sample"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/wallet_logo"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="5dp"
            android:layout_marginEnd="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="dPay"
            android:textSize="30sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:id="@+id/qrUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bijaya Sigdel"
        android:textSize="32sp"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/qrDpayId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="bijayasigdel123@gmail.com"
        android:textSize="23sp"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan QR code to receive money"
        android:textSize="23sp"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        android:layout_marginTop="30dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_margin="20dp">

        <LinearLayout
            android:id="@+id/downloadContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/download"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download"
                android:textSize="23sp"
                android:textColor="@color/black"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="70dp"
            android:layout_height="0dp"/>


        <LinearLayout
            android:id="@+id/shareContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/share"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:textSize="23sp"
                android:textColor="@color/black"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold" />
        </LinearLayout>



    </LinearLayout>


</LinearLayout>